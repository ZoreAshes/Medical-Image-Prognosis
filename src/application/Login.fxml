<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="application.Controller"
           prefHeight="500"
           prefWidth="700"
           stylesheets="@login.css">

    <BorderPane prefHeight="500" prefWidth="700">

        <left>
            <AnchorPane prefWidth="350" styleClass="left-pane">

                <VBox alignment="CENTER"
                      spacing="15"
                      layoutX="90"
                      layoutY="150">

                    <Text text="⚕" styleClass="doctor-icon"/>
                    <Text text="Xpert" styleClass="app-title"/>
                    <Text text="Medical Management System"
                          styleClass="app-subtitle"/>

                </VBox>

            </AnchorPane>
        </left>

        <center>
            <AnchorPane prefWidth="350">

                <Button layoutX="315"
                        layoutY="10"
                        text="X"
                        onAction="#cancelbutton"
                        styleClass="close-btn"/>

                <VBox layoutX="70"
                      layoutY="130"
                      spacing="15"
                      alignment="CENTER"
                      styleClass="login-card">

                    <Text text="User Login"
                          styleClass="login-title"/>

                    <TextField fx:id="usernameText"
                               promptText="Username"
                               prefWidth="200"
                               styleClass="input-field"/>

                    <PasswordField fx:id="passwordText"
                                   promptText="Password"
                                   prefWidth="200"
                                   styleClass="input-field"/>

                    <Button text="Login"
                            prefWidth="160"
                            onAction="#loginButton"
                            styleClass="login-btn"/>

                    <Label fx:id="loginMessage"
                           prefWidth="200"
                           textAlignment="CENTER"
                           styleClass="error-label"/>

                    <Hyperlink text="Forgot Password?"
                               styleClass="forgot-link"/>

                </VBox>

            </AnchorPane>
        </center>

    </BorderPane>

    <AnchorPane fx:id="welcomePane"
                prefHeight="500"
                prefWidth="700"
                styleClass="welcome-pane">

        <VBox alignment="CENTER"
              spacing="20"
              layoutX="200"
              layoutY="150">

            <Text text="⚕" styleClass="doctor-icon"/>

            <Text text="Xpert"
                  styleClass="app-title"/>

            <Text text="Welcome to the Medical Management System"
                  styleClass="app-subtitle"/>

            <Button text="Login"
                    styleClass="welcome-login-btn"
                    onAction="#showLogin"
                    prefWidth="220"
                    prefHeight="45"/>

        </VBox>

    </AnchorPane>

</StackPane>